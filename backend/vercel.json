# Create a clean version
@'
{
    "functions": {
        "app/main.py": {
            "runtime": "python3.9"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app/main.py"
        }
    ]
}
'@ | Out-File -FilePath backend/vercel.json -Encoding utf8

# Verify it's valid
Get-Content backend/vercel.json