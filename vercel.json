# Update root vercel.json with correct runtime
@'
{
    "functions": {
        "api/index.py": {
            "runtime": "python3.9"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ]
}
'@ | Out-File -FilePath vercel.json -Encoding utf8